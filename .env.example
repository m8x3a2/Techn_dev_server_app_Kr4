# .env.example — шаблон переменных окружения
# Скопируйте в .env и заполните своими значениями

# URL базы данных
# SQLite (по умолчанию, файл создаётся автоматически):
DATABASE_URL=sqlite:///./kr4.db

# PostgreSQL (раскомментируйте и настройте при необходимости):
# DATABASE_URL=postgresql://user:password@localhost:5432/kr4_db
